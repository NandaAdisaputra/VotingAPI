{
    // ===============================
    // KONFIGURASI CONNECTION DATABASE
    // ===============================
    "ConnectionStrings": {

        // Connection string untuk SQL Server
        // Server=localhost -> database berada di komputer lokal
        // Database=db_osis_voting -> nama database
        // Trusted_Connection=True -> menggunakan Windows Authentication
        // TrustServerCertificate=True -> mengizinkan sertifikat lokal
        "DefaultConnection": "Server=localhost;Database=db_osis_voting;Trusted_Connection=True;TrustServerCertificate=True;"
    },

    // ===============================
    // KONFIGURASI LOGGING
    // ===============================
    "Logging": {
        "LogLevel": {

            // Level log default aplikasi
            // Information = menampilkan info penting aplikasi
            "Default": "Information",

            // Log khusus ASP.NET Core
            // Warning = hanya menampilkan peringatan
            "Microsoft.AspNetCore": "Warning"
        }
    },

    // ===============================
    // KONFIGURASI HOST
    // ===============================

    // Menentukan host yang boleh mengakses aplikasi
    // "*" artinya semua host diperbolehkan
    "AllowedHosts": "*"
}